{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/predict.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/health.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/metrics.py",
      "use": "@vercel/python"
    },
    {
      "src": "templates/dashboard.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/templates/dashboard.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/predict",
      "dest": "/api/predict.py"
    },
    {
      "src": "/model/metrics",
      "dest": "/api/metrics.py"
    }
  ]
}