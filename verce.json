{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.9"
      }
    },
    {
      "src": "templates/dashboard.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/templates/dashboard.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/predict",
      "dest": "/api/predict.py"
    },
    {
      "src": "/model/metrics",
      "dest": "/api/metrics.py"
    },
    {
      "src": "/model/recent_predictions",
      "dest": "/api/recent_predictions.py"
    }
  ]
}